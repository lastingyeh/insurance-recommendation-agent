# GOOGLE_API_KEY=your-api-key

## Vertex AI 專案的 Google Cloud project ID
GOOGLE_CLOUD_PROJECT=gcp-project-name

## Vertex AI 的 Google Cloud 區域
GOOGLE_CLOUD_LOCATION=vertai-support-location

## 是否使用 Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=1

ADK_SESSION_DB_URI=sqlite+aiosqlite:///./db/adk_sessions.db
ADK_MEMORY_MODE=in_memory
TOOLBOX_SERVER_URL=http://127.0.0.1:5000
ADK_APP_NAME=app

MODEL_NAME=gemini-3.1-flash-lite-preview